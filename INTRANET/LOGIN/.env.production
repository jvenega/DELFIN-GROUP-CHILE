# VITE_MAINTENANCE=true
VITE_API_URL=

VITE_BASE_PATH="/intranet"


VITE_SESSION_IDLE_MS=900000 # 15 minutes
VITE_SESSION_WARN_BEFORE_MS=600000 # 10 minutes
VITE_SESSION_STORAGE_KEY=SESSION_EXP_AT # Key used in localStorage to store session expiration timestamp
VITE_SESSION_BROADCAST_KEY=SESSION_EVENT # Key used in localStorage to broadcast session events across tabs


VITE_SUBAPP_MIN_CHECK_TIME=1200
VITE_SUBAPP_CACHE_TTL=30000
VITE_SUBAPP_IFRAME_POOL_LIMIT=15
VITE_SUBAPP_TIMEOUT=3000